# ──────────────────────────────────────────────────────────────────────────
# LinkedIn Job Scraper Environment Variables Configuration
# ──────────────────────────────────────────────────────────────────────────

# If these variables are set, the scraper and dashboard server will connect
# to Supabase as their backend storage database.
# If these variables are empty or commented out, the application will fallback
# automatically to a local SQLite database named 'linkedin_jobs.db'.

# Your Supabase Project API URL (found in Settings -> API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase Project Anon/Public Key (found in Settings -> API)
SUPABASE_ANON_KEY=your-public-anon-key

# Your Supabase Project Service Role JWT Key (found in Settings -> API)
# WARNING: This key grants full bypass of RLS policies. Keep it private.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-scraper-only
